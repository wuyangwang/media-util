{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:default",
    "shell:allow-execute",
    "dialog:default",
    "updater:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        {
          "url": "https://github.com/wuyangwang/media-util"
        }
      ]
    },
    "store:default",
    "log:default",
    "fs:default",
    "window-state:default",
    "single-instance:default",
    "os:default"
  ]
}