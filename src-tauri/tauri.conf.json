{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Media Utility",
	"version": "0.1.0",
	"identifier": "com.jdd.media-util",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "Media Utility",
				"width": 1000,
				"height": 700
			}
		],
		"security": {
			"csp": null
		},
		"updater": {
			"endpoints": [
				"https://example.com/updates/{{target}}-{{arch}}.json"
			],
			"pubkey": "SET_YOUR_PUBLIC_KEY_HERE"
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"externalBin": [
			"binaries/ffmpeg",
			"binaries/ffprobe"
		],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
