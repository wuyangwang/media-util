{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Media Utility",
	"version": "1.0.3",	"identifier": "com.wjt.media-util",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "媒体助手",
				"width": 1000,
				"height": 700,
				"center": true
			}
		],
		"security": {
			"csp": null,
			"assetProtocol": {
				"enable": true,
				"scope": ["**"]
			}
		}
	},
	"plugins": {
		"updater": {
			"endpoints": ["https://example.com/updates/{{target}}-{{arch}}.json"],
			"pubkey": "SET_YOUR_PUBLIC_KEY_HERE"
		}
	},
	"bundle": {
		"active": true,
		"targets": ["nsis", "msi"],
		"externalBin": ["binaries/ffmpeg", "binaries/ffprobe"],
		"icon": ["icons/128x128@2x.png", "icons/icon.ico"]
	}
}
